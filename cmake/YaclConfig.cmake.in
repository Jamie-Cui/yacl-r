@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

set(_yacl_saved_module_path "${CMAKE_MODULE_PATH}")
list(PREPEND CMAKE_MODULE_PATH "${CMAKE_CURRENT_LIST_DIR}")

find_dependency(Threads REQUIRED)
find_dependency(GMP REQUIRED)

set(CMAKE_MODULE_PATH "${_yacl_saved_module_path}")
unset(_yacl_saved_module_path)

include("${CMAKE_CURRENT_LIST_DIR}/YaclDeps.cmake")
include("${CMAKE_CURRENT_LIST_DIR}/YaclTargets.cmake")

check_required_components(Yacl)
